#!/bin/bash
# hooks/block-dangerous
# PreToolUse hook: blocks dangerous Bash commands before they execute.

# Read JSON input from stdin
INPUT=$(cat)

# Extract the command from the JSON
COMMAND=$(echo "$INPUT" | jq -r '.tool_input.command // empty')

if [ -z "$COMMAND" ]; then
  exit 0
fi

# ---- Allowlist: targeted Java file removal (for unused class cleanup) ----
# Allow: rm of specific .java files (no -rf, no wildcards)
# e.g. "rm src/main/java/com/example/UnusedService.java"
if echo "$COMMAND" | grep -qE '^rm\s+[^-].*\.java$'; then
  exit 0
fi

# ---- Blocklist: dangerous patterns ----
BLOCKED=false
REASON=""

# 1. Recursive force delete
if echo "$COMMAND" | grep -qE 'rm\s+(-[a-zA-Z]*r[a-zA-Z]*f|--recursive|--force|-[a-zA-Z]*f[a-zA-Z]*r)\b'; then
  BLOCKED=true
  REASON="Recursive force deletion (rm -rf) is blocked"
fi

# 2. Dangerous SQL operations
if echo "$COMMAND" | grep -qiE '\b(DROP\s+(TABLE|DATABASE|SCHEMA)|TRUNCATE\s+TABLE)\b'; then
  BLOCKED=true
  REASON="Destructive SQL operation is blocked"
fi

# 3. Wiping build caches or entire directories
if echo "$COMMAND" | grep -qE 'rm\s+.*(/\.m2/|/\.gradle/|/target/\*|/build/\*)'; then
  BLOCKED=true
  REASON="Build cache/directory wipe is blocked"
fi

# 4. Deletion of sensitive config files
if echo "$COMMAND" | grep -qE 'rm\s+.*\.(env|envrc|properties|yml|sql|pem|key|p12|jks)(\s|$)'; then
  BLOCKED=true
  REASON="Deletion of sensitive config/credential files is blocked"
fi

# 5. Wildcard rm on non-.java files
if echo "$COMMAND" | grep -qE 'rm\s+.*\*' && ! echo "$COMMAND" | grep -qE '\*\.java(\s|$)'; then
  BLOCKED=true
  REASON="Wildcard deletion is blocked"
fi

# ---- Decision ----
if [ "$BLOCKED" = true ]; then
  # Exit 2 = blocking error; stderr is fed back to Claude
  echo "$REASON" >&2
  jq -n \
    --arg reason "$REASON" \
    '{
      hookSpecificOutput: {
        hookEventName: "PreToolUse",
        permissionDecision: "deny",
        permissionDecisionReason: $reason
      }
    }'
  exit 2
fi

exit 0
